{
  "name": "visio-azure",
  "version": "1.0.0",
  "description": "AI Vision Assistant powered by Azure OpenAI GPT-4o Mini",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "echo 'No build step — static frontend served from /public'"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "nodemonConfig": {
    "watch": ["server.js", ".env"],
    "ext": "js,json",
    "delay": 500
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
