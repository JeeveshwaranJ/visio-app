# Rename this file to .env — never commit it to git

# ── Azure OpenAI ────────────────────────────────────────────────────────────
# Find these in: Azure Portal → your OpenAI resource → Keys and Endpoint
AZURE_OPENAI_API_KEY=your-azure-api-key-here
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com

# Find this in: Azure AI Studio → Deployments
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# API version — 2024-04-01-preview supports vision
AZURE_API_VERSION=2024-04-01-preview

